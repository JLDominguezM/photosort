# Absolute path to the folder containing your photos.
# Mounted read-only into the backend container.
PHOTOS_DIR=/path/to/your/photos

# "cuda" for NVIDIA GPU acceleration, "cpu" for CPU-only mode.
DEVICE=cuda

# Comma-separated list of allowed CORS origins for the API.
# The built-in frontend is served at http://localhost:8080 by default.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Logging level for the backend: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# The following two are set automatically by docker-compose.yml.
# Override only if running the backend outside Docker.
# DATA_DIR=./backend/data
# CONFIG_DIR=./config
